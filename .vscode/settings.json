{
  "protoc": {
    "options": [
      "--proto_path=${workspaceFolder}/generated/proto"
    ]
  },
  // 在vscode扩展中安装 vscode-protoc3
  "[proto3]": {
    "editor.defaultFormatter": "zxh404.vscode-proto3",
    "editor.formatOnSave": true
  },
  // 在vscode扩展中安装 filewatcher
  "filewatcher.commands": [
    {
      "match": "\\.proto$",
      "event": "onFileChange",
      "isAsync": false,
      "cmd": "${fileDirname}\\..\\generated-golang.bat",
    }
  ]
}